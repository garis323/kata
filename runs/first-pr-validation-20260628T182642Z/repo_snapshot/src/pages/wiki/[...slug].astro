---
import { getCollection, render } from 'astro:content';
import WikiLayout from '../../layouts/WikiLayout.astro';
import Hovercards from '../../components/Hovercards.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import { resolveArticleImageSource } from '../../lib/article-image-assets.js';
import { buildSlugAliases, parseWikiLinkTokens, resolveTargetSlug } from '../../../scripts/wiki-link-resolver.js';
import { getPageSlug } from '../../lib/article-history';
import { publishedTitleBySlug } from '../../lib/article-metadata';
import { getArticleToc } from '../../lib/article-toc.js';
import { getRelatedPages } from '../../lib/related-pages';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  // Related-pages inputs: the build-time link graph + category index (the same
  // public/data/*.json the What-links-here page and broken-link detection use).
  // Globbed inside getStaticPaths because Astro runs this function isolated from
  // the module scope. The page body used to re-run getCollection('pages'),
  // rebuild titleBySlug across the whole collection, and call getRelatedPages on
  // every one of the article pages (O(N) work per page); computing each
  // article's related set once here mirrors related.json's getStaticPaths.
  const categoriesModules = import.meta.glob('../../../public/data/categories.json', { eager: true }) as Record<
    string,
    { default?: Record<string, string[]> }
  >;
  const backlinksModules = import.meta.glob('../../../public/data/backlinks.json', { eager: true }) as Record<
    string,
    { default?: Record<string, Array<{ from: string }>> }
  >;
  const linkgraphModules = import.meta.glob('../../../public/data/linkgraph.json', { eager: true }) as Record<
    string,
    { default?: Record<string, Array<{ target: string }>> }
  >;
  const categoriesIndex = Object.values(categoriesModules)[0]?.default ?? {};
  const backlinksData = Object.values(backlinksModules)[0]?.default ?? {};
  const linkgraphData = Object.values(linkgraphModules)[0]?.default ?? {};

  let slugMap: Record<string, { title?: string; categories?: string[]; summary?: string }> = {};
  try {
    const slugData = await import('../../../public/data/slugmap.json');
    slugMap = slugData.default as typeof slugMap;
  } catch (e) {
    // Slug map not yet generated
  }

  const titleBySlug = publishedTitleBySlug();
  const publishedSlugs = new Set(Object.keys(titleBySlug));

  return pages.map((page) => {
    const slug = getPageSlug(page);
    const relatedPages = getRelatedPages({
      slug,
      slugMap,
      categoriesIndex,
      backlinks: backlinksData,
      outgoing: linkgraphData,
      publishedSlugs,
      titleBySlug,
      max: 4,
    });
    return {
      params: { slug },
      props: { page, slug, relatedPages },
    };
  });
}

const { page, slug, relatedPages } = Astro.props;
const { Content, headings } = await render(page);
const tocHeadings = getArticleToc(headings);

// Try to load per-article infobox.json if present
const infoboxModules = import.meta.glob('../../content/pages/**/infobox.json', { eager: true }) as Record<string, any>;
const articleImageAssets = import.meta.glob('../../content/pages/**/*.{avif,gif,jpg,jpeg,png,webp}', {
  eager: true,
  query: '?url&no-inline',
  import: 'default',
}) as Record<string, string>;
let infobox: any = null;
for (const [p, mod] of Object.entries(infoboxModules)) {
  if (p.endsWith(`/${slug}/infobox.json`)) {
    infobox = (mod && (mod.default ?? mod)) as any;
    break;
  }
}

// Compose a unified infobox object, preferring frontmatter over per-folder JSON
const ib = {
  title: page.data.infoboxTitle ?? infobox?.title,
  image: resolveArticleImageSource(
    slug,
    page.data.coverImage ?? page.data.infoboxImage ?? infobox?.image,
    articleImageAssets,
  ),
  caption: page.data.infoboxCaption ?? infobox?.caption,
  rows: page.data.infoboxRows ?? infobox?.rows,
};

// Load slug map for broken link detection
let slugMap = {};
try {
  const slugData = await import('../../../public/data/slugmap.json');
  slugMap = slugData.default;
} catch (e) {
  // Slug map not yet generated
}
const slugAliases = buildSlugAliases(slugMap);
const validSlugs = Object.keys(slugMap);

// relatedPages is precomputed once per route in getStaticPaths (see above) and
// passed via props, instead of re-reading the whole content collection on every
// article page.

function renderInfoboxValue(value: string) {
  return parseWikiLinkTokens(value).map((token) => {
    if (token.type !== 'link') return token;

    const targetSlug = resolveTargetSlug(token.target, slugAliases);
    return {
      ...token,
      href: `/wiki/${targetSlug}/`,
      exists: Object.prototype.hasOwnProperty.call(slugMap, targetSlug),
    };
  });
}

const historyUrl = `/wiki/${slug}/history/`;
const backlinksUrl = `/wiki/${slug}/backlinks/`;
const citeUrl = `/wiki/${slug}/cite/`;
const infoUrl = `/wiki/${slug}/info/`;

// Breadcrumb: Home › primary topic › this article. The primary topic is the
// article's first category (frontmatter order), matching the Schema.org
// BreadcrumbList emitted in the page head. Articles with no category degrade to
// Home › this article.
const primaryTopic = page.data.categories?.[0];
const primaryTopicUrl = primaryTopic ? `/wiki/category/${primaryTopic.replace(/ /g, '_')}/` : undefined;
// Footer topic chips dedupe repeated frontmatter categories so a duplicated tag
// cannot render the same topic link twice on the article page.
const articleTopics = [...new Set(page.data.categories ?? [])];
const serializedValidSlugs = JSON.stringify(validSlugs).replace(/</g, '\\u003c');

// Article metadata footer: the last-modified date (newest-first revision from
// the build-time history at public/history/<slug>.json, same source as the
// sitemap <lastmod> and the history page) and an estimated reading time from
// the article body. Shown to readers as a freshness + length signal.
const articleHistory = import.meta.glob('../../../public/history/**/*.json', { eager: true }) as Record<
  string,
  { default?: { history?: Array<{ date?: string }> } }
>;
const lastUpdated = articleHistory[`../../../public/history/${slug}.json`]?.default?.history?.[0]?.date ?? '';
const lastUpdatedLabel = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const wordCount = (page.body ?? '').trim().split(/\s+/).filter(Boolean).length;
// ~200 wpm, rounded UP so any non-empty article reads as at least 1 min and a
// 201-word article reads as 2 min (not under-reported as 1).
const readingMinutes = Math.max(1, Math.ceil(wordCount / 200));
---

<WikiLayout
  title={page.data.title}
  description={page.data.summary}
  image={`/og/${slug}.png`}
  type="article"
>
  {tocHeadings.length > 0 && (
    <div slot="sidebar" class="toc-sidebar" role="navigation" aria-labelledby="toc-heading">
      <div class="toc-sidebar-inner">
        <div class="toc-header">
          <div class="toc-title" id="toc-heading">Contents</div>
          <button class="toc-hide" type="button" aria-label="Hide table of contents">hide</button>
        </div>
        <ul class="toc-list">
          {tocHeadings.map((heading) => {
            return (
              <li 
                class={`toc-level-${heading.depth}${heading.isSubsection ? ' toc-subsection' : ''}`} 
                data-toc-level={heading.depth}
                style={`padding-left: ${heading.indent}px;`}
              >
                <div class="toc-item-wrapper">
                  {heading.hasSubsections ? (
                    <button class="toc-toggle" aria-label="Toggle subsections" data-slug={heading.slug}>
                      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                  ) : (
                    <span class="toc-spacer"></span>
                  )}
                  <a href={`#${heading.slug}`} class={heading.hasSubsections ? 'has-subsections' : ''}>
                    <span class="toc-number">{heading.number}</span> {heading.title}
                  </a>
                </div>
              </li>
            );
          })}
        </ul>
        <div class="toc-footer">
          <a href="#" class="toc-back-to-top">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M6 9V3M6 3L3 6M6 3L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to top
          </a>
        </div>
      </div>
    </div>
  )}

  <div class="mw-body-content" data-pagefind-body>
    <nav class="mw-breadcrumb" aria-label="Breadcrumb" data-pagefind-ignore>
      <ol>
        <li><a href="/">Home</a></li>
        {primaryTopic && (
          <li><a href={primaryTopicUrl}>{primaryTopic}</a></li>
        )}
        <li><span aria-current="page">{page.data.title}</span></li>
      </ol>
    </nav>
    <h1 class="firstHeading" data-pagefind-meta="title">{page.data.title}</h1>

    <nav class="mw-article-toolbar" data-pagefind-ignore>
      <button class="sidebar-toggle toolbar-toggle" aria-label="Toggle navigation">☰</button>
      <a href={`/wiki/${slug}/`} class="active" aria-current="page">Article</a>
      <a href={historyUrl}>History</a>
      <a href={backlinksUrl}>What links here</a>
      <a href={citeUrl}>Cite this page</a>
      <a href={infoUrl}>Page information</a>
      <span class="toolbar-spacer"></span>
      <button class="appearance-toggle toolbar-toggle" type="button" aria-label="Show appearance controls" aria-expanded="true">
        Aa
      </button>
    </nav>

    {page.data.summary && (
      <div class="mw-article-summary" data-pagefind-meta="summary" style="font-style: italic; margin-bottom: 16px; color: var(--color-base-subtle);">
        {page.data.summary}
      </div>
    )}

    <div class="mw-parser-output">
      {/** Infobox (prefer per-article file) */}
      {(ib.title || ib.image || (ib.rows && ib.rows.length > 0)) && (
        <aside
          class="infobox"
          aria-labelledby={ib.title ? 'infobox-title' : undefined}
          aria-label={ib.title ? undefined : 'Infobox'}
        >
          {ib.title && (
            <div class="infobox-title" id="infobox-title">{ib.title}</div>
          )}
          {ib.image && (
            <img class="infobox-image" src={ib.image} alt={ib.title || page.data.title} />
          )}
          {ib.caption && (
            <div style="font-size: 12px; padding: 6px 12px; color: var(--color-base-subtle);">{ib.caption}</div>
          )}
          {ib.rows && ib.rows.length > 0 && (
            <table class="infobox-table">
              <tbody>
                {ib.rows.map((row: { label: string; value: string }) => (
                  <tr>
                    <th scope="row">{row.label}</th>
                    <td>
                      {renderInfoboxValue(row.value).map((part) =>
                        part.type === 'link' ? (
                          <a class={part.exists ? 'internal' : 'internal new'} href={part.href}>{part.text}</a>
                        ) : (
                          part.text
                        )
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </aside>
      )}
      <Content />
    </div>

    {relatedPages.length > 0 && (
      <section class="related-pages" aria-labelledby="related-pages-heading" data-pagefind-ignore>
        <h2 id="related-pages-heading">Related pages</h2>
        <ul class="related-pages-list">
          {relatedPages.map((r) => (
            <li class="related-pages-item">
              <a class="related-pages-card" href={`/wiki/${r.slug}/`}>
                <span class="related-pages-title">{r.title}</span>
                {r.summary && <span class="related-pages-summary">{r.summary}</span>}
                {r.tags.length > 0 && (
                  <span class="related-pages-tags">
                    {r.tags.map((t) => (
                      <span class="related-pages-tag">{t}</span>
                    ))}
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {articleTopics.length > 0 && (
      <div class="article-topics" data-pagefind-ignore>
        <span>Topics</span>
        {articleTopics.map((cat: string) => (
          <a data-pagefind-filter="category" href={`/wiki/category/${cat.replace(/ /g, '_')}/`}>{cat}</a>
        ))}
      </div>
    )}

    <div
      class="mw-article-meta"
      data-pagefind-ignore
      data-word-count={wordCount}
      style="margin-top: 24px; padding-top: 12px; border-top: 1px solid var(--border-color-subtle); font-size: 13px; color: var(--color-base-subtle);"
    >
      {lastUpdatedLabel && (
        <span>Last updated <time datetime={lastUpdated}>{lastUpdatedLabel}</time> (UTC)</span>
      )}
      {lastUpdatedLabel && <span aria-hidden="true"> · </span>}
      <span>{readingMinutes} min read</span>
    </div>
  </div>

  <script type="application/json" id="valid-slugs-data" set:html={serializedValidSlugs} />
  <script is:inline>
    // Unlink wiki links that point to non-existent pages
    document.addEventListener('DOMContentLoaded', () => {
      const validSlugsEl = document.getElementById('valid-slugs-data');
      const validSlugs = new Set(validSlugsEl ? JSON.parse(validSlugsEl.textContent || '[]') : []);
      const container = document.querySelector('.mw-parser-output');
      if (!container) return;
      const anchors = container.querySelectorAll('a.internal');
      anchors.forEach((a) => {
        const href = a.getAttribute('href') || '';
        // Expect /wiki/<slug>/ (canonical trailing slash); tolerate a missing
        // slash and ignore any #fragment/?query so the slug matches validSlugs.
        const m = href.match(/^\/wiki\/([^#?]+?)\/?(?:[#?]|$)/);
        const slug = m ? m[1] : null;
        const isMissing = !slug || !validSlugs.has(slug);
        if (isMissing) {
          const span = document.createElement('span');
          span.textContent = a.textContent || '';
          a.replaceWith(span);
        }
      });
    });
  </script>

  <Hovercards />
  <ReadingProgress />
</WikiLayout>
