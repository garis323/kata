---
// Copy-to-clipboard buttons for the per-article "Cite this page" citations.
// Progressive enhancement: the page already renders each citation in a
// <pre class="mw-cite-text" data-cite="..."> under "Copy a ready-made citation
// in your preferred style." This adds a one-click Copy button to each block.
//
// No framework, no new dependencies. With JS off — or if the Clipboard API is
// unavailable — no button is added and the citation text stays selectable, so
// nothing regresses. Button labels/feedback are set via textContent only.
---

<script is:inline>
  (function () {
    if (window.__taopediaCopyCite) return;
    window.__taopediaCopyCite = true;

    function init() {
      var clip = navigator.clipboard;
      // No dead control: only enhance when we can actually copy. The <pre> text
      // remains manually selectable otherwise.
      if (!clip || !clip.writeText) return;

      var blocks = document.querySelectorAll('.mw-cite-block');
      Array.prototype.forEach.call(blocks, function (block) {
        var pre = block.querySelector('pre.mw-cite-text[data-cite]');
        if (!pre || block.querySelector('.mw-cite-copy')) return;

        var labelEl = block.querySelector('.mw-cite-label');
        var styleName = labelEl ? labelEl.textContent.trim() : '';

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'mw-cite-copy';
        btn.textContent = 'Copy';
        btn.setAttribute('aria-label', styleName ? 'Copy ' + styleName + ' citation' : 'Copy citation');

        // Visually-hidden polite live region announces success/failure to AT.
        // role="status" already implies aria-live="polite".
        var status = document.createElement('span');
        status.className = 'mw-cite-copy-status';
        status.setAttribute('role', 'status');

        block.appendChild(btn);
        block.appendChild(status);

        var resetTimer = 0;
        btn.addEventListener('click', function () {
          clip.writeText(pre.textContent).then(
            function () {
              btn.textContent = 'Copied!';
              btn.classList.add('is-copied');
              status.textContent = (styleName ? styleName + ' ' : '') + 'citation copied to clipboard';
              clearTimeout(resetTimer);
              resetTimer = setTimeout(function () {
                btn.textContent = 'Copy';
                btn.classList.remove('is-copied');
                status.textContent = '';
              }, 2000);
            },
            function () {
              status.textContent = 'Copy failed — select the text to copy it manually';
            },
          );
        });
      });
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>
