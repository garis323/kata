---
import WikiLayout from '../../../layouts/WikiLayout.astro';
import { buildCategories } from '../../../../scripts/categories.js';
import categoriesIndex from '../../../../public/data/categories.json';

// Read public/data/categories.json — the same artifact categories.json (#1403)
// and feeds.opml (#1299) use — instead of calling getCollection('pages') and
// re-scanning every article's categories frontmatter.
const sortedCategories = buildCategories({ categoriesIndex });
---

<WikiLayout title="Categories" description="Browse all topics in the Taopedia Bittensor knowledge base.">
  <div class="mw-body-content">
    <h1 class="firstHeading">Topics</h1>
    
    <div class="mw-parser-output">
      <div class="categories-list">
        <h2 id="categories">All Topics ({sortedCategories.length})</h2>
        <ul>
          {sortedCategories.map((topic) => (
            <li>
              <a href={`/wiki/category/${topic.slug}/`}>
                {topic.name}
              </a>
              <span class="category-count">
                ({topic.count} page{topic.count !== 1 ? 's' : ''})
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</WikiLayout>

<style>
  .categories-list ul {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 3;
    column-gap: 24px;
  }
  
  .categories-list li {
    margin: 8px 0;
    break-inside: avoid;
    padding: 8px;
    background: var(--background-color-interactive);
    border-radius: 4px;
  }
  
  .categories-list a {
    font-weight: 600;
    color: var(--color-link);
    text-decoration: none;
  }
  
  .categories-list a:hover {
    text-decoration: underline;
  }
  
  .category-count {
    color: var(--color-base-subtle);
    font-size: 13px;
    margin-left: 8px;
  }
  
  @media (max-width: 900px) {
    .categories-list ul {
      columns: 2;
    }
  }
  
  @media (max-width: 600px) {
    .categories-list ul {
      columns: 1;
    }
  }
</style>
