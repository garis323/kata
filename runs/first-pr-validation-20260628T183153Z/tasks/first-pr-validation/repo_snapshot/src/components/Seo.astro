---
import StructuredData from './StructuredData.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  path?: string;
  // Per-page feed alternates (e.g. a category hub advertising its own RSS/JSON
  // feed). Rendered after the site-wide feeds so a feed reader landing on the
  // page can auto-discover the scoped feed, not just /rss.xml and /feed.json.
  feeds?: Array<{ type: string; title: string; href: string }>;
  robots?: string;
}

const defaultTitle = 'Taopedia';
const defaultDescription =
  'A Bittensor-focused knowledge base for TAO, subnets, wallets, staking, mining, validation, and consensus.';

const { title, description = defaultDescription, image = '/og/home.png', type = 'website', path, feeds, robots } =
  Astro.props;

const pageTitle = title ? `${title} - Taopedia` : defaultTitle;
const canonicalUrl = new URL(path ?? Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();
// Describe what the share card actually shows, rather than a generic
// "<title> share image", so it's useful to screen readers and link previews.
const imageAlt = title
  ? `${title} — Taopedia, a Bittensor knowledge base`
  : 'Taopedia — a Bittensor knowledge base';
---

{/* Apply the saved color theme before paint, so a reader who chose Dark never
    sees a flash of the light theme. Kept in this shared <head> component so it
    covers both the layout pages and the standalone homepage. The Appearance
    panel's Color control keeps the stored preference in sync at runtime. */}
<script is:inline>
  try {
    if (localStorage.getItem('taopedia-color') === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  } catch (e) {}
</script>

<title>{pageTitle}</title>
<meta name="description" content={description} />
{robots && <meta name="robots" content={robots} />}
<link rel="canonical" href={canonicalUrl} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" sizes="32x32" type="image/png" href="/favicon-32x32.png" />
<link rel="icon" sizes="16x16" type="image/png" href="/favicon-16x16.png" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link
  rel="search"
  type="application/opensearchdescription+xml"
  title="Taopedia"
  href="/opensearch.xml"
/>
<link rel="alternate" type="application/rss+xml" title="Taopedia" href="/rss.xml" />
<link rel="alternate" type="application/atom+xml" title="Taopedia" href="/atom.xml" />
<link rel="alternate" type="application/feed+json" title="Taopedia" href="/feed.json" />
<link rel="alternate" type="text/x-opml" title="Taopedia feeds" href="/feeds.opml" />
{(feeds ?? []).map((feed) => (
  <link rel="alternate" type={feed.type} title={feed.title} href={feed.href} />
))}

<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Taopedia" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={imageAlt} />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={imageAlt} />

<StructuredData
  title={title}
  description={description}
  image={image}
  type={type}
  canonicalUrl={canonicalUrl}
  siteDescription={defaultDescription}
/>
