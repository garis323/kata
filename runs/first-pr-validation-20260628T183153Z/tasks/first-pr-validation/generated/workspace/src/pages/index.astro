---
import '../styles/wikipedia.css';
import Seo from '../components/Seo.astro';
import SearchSuggest from '../components/SearchSuggest.astro';
import { sortPagesByTitle, compareTitles } from '../lib/title-sort.js';
import { allRecentChanges } from '../lib/article-history';
import {
  pageFromSlug,
  pagesFromSlugMap,
  publishedTitleBySlug,
  sortedPagesFromSlugMap,
} from '../lib/article-metadata';
import { formatRevisionDate } from '../lib/format-date.js';
import { buildSubnets } from '../../scripts/subnets.js';
import slugMap from '../../public/data/slugmap.json';
import categoriesIndex from '../../public/data/categories.json';

// Read public/data/slugmap.json and categories.json for landing-page directory
// metadata — the same artifacts allpages.json (#1240) and categories.json
// (#1403) use — instead of calling getCollection('pages') and re-scanning every
// article's frontmatter.
const sortedPages = sortedPagesFromSlugMap(slugMap);
const getPageSlug = (page: { id: string }) =>
  page.id.replace(/\/index\.(md|mdx)$/, '').replace(/\/index$/, '').replace(/\.(md|mdx)$/, '');

type PageEntry = (typeof sortedPages)[number];

const categoryIndex = new Map<string, PageEntry[]>();
for (const [categoryName, slugs] of Object.entries(categoriesIndex)) {
  const topicPages = sortPagesByTitle(
    (Array.isArray(slugs) ? slugs : [])
      .map((slug) => pageFromSlug(slug, slugMap))
      .filter((page): page is PageEntry => page !== null),
  );
  if (topicPages.length > 0) categoryIndex.set(categoryName, topicPages);
}

const priorityCategories = ['Wallets', 'Subnets', 'Mining', 'Staking', 'Consensus', 'Tokenomics'];
const topicCategories = priorityCategories
  .map((name) => [name, categoryIndex.get(name)] as const)
  .filter((entry): entry is readonly [string, PageEntry[]] => Boolean(entry[1]));

const featuredSlugs = [
  'dynamic_tao',
  'yuma_consensus',
  'wallets_coldkey_hotkey',
  'mining_and_validating',
];
const featuredPages = featuredSlugs
  .map((slug) => pageFromSlug(slug, slugMap))
  .filter((page): page is PageEntry => page !== null);

// Featured subnets for landing-page discovery. Subnets are the defining
// Bittensor entity, but the homepage otherwise never surfaces an individual one
// (only the broad "Subnets" topic). Show the foundational low-netuid subnets —
// excluding any retired/"Deprecated" entry — as a restrained taster that links
// into the full Special:Subnets directory. Reuses the same buildSubnets() helper
// that powers Special:Subnets and subnets.json, so the homepage can never
// disagree with them on netuid, name, or slug. Refs #521.
const featuredSubnets = buildSubnets({ pages: pagesFromSlugMap(slugMap), getPageSlug })
  .filter((subnet) => !/deprecated/i.test(subnet.name))
  .slice(0, 6);

// Most recently updated articles, newest first — the one piece of information
// the landing page otherwise never shows (it carries no dates at all). Reuses
// the same allRecentChanges() source as Special:RecentChanges; that flattens to
// one entry per commit, so dedupe by slug to list each article once. The
// featured Core Articles above are excluded so the two curated sections never
// surface the same title twice on the page. limit 0 = consider every change,
// then keep the newest distinct articles.
const titleBySlug = publishedTitleBySlug();

const featuredSlugSet = new Set(featuredSlugs);
const seenRecent = new Set<string>();
const recentlyUpdated: Array<{ slug: string; title: string; date: string }> = [];
for (const change of allRecentChanges(titleBySlug, 0)) {
  if (seenRecent.has(change.slug) || featuredSlugSet.has(change.slug)) continue;
  seenRecent.add(change.slug);
  recentlyUpdated.push(change);
  if (recentlyUpdated.length >= 6) break;
}

const alphaGroups = new Map<string, PageEntry[]>();
for (const page of sortedPages) {
  const firstLetter = page.data.title.trim().charAt(0).toUpperCase();
  const group = /^[A-Z]$/.test(firstLetter) ? firstLetter : '#';
  const existing = alphaGroups.get(group) ?? [];
  existing.push(page);
  alphaGroups.set(group, existing);
}

const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').filter((letter) => alphaGroups.has(letter));
const groupedPages = [...alphaGroups.entries()].sort(([a], [b]) => {
  if (a === '#') return 1;
  if (b === '#') return -1;
  return compareTitles(a, b);
});

const initialLetter = alphabet[0] ?? '#';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo
      title="Bittensor Knowledge Base"
      description="A Bittensor-focused knowledge base for TAO, subnets, wallets, staking, mining, validation, and consensus."
      image="/og/home.png"
      path="/"
    />
    <style>
      body {
        margin: 0;
        font-family: var(--font-family-sans);
        color: var(--color-base);
        background: var(--background-color-base);
      }

      .home-shell {
        max-width: 1080px;
        margin: 0 auto;
        padding: 32px 24px 56px;
      }

      .home-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding-bottom: 24px;
        border-bottom: 1px solid var(--border-color-subtle);
      }

      .home-brand {
        display: inline-flex;
        align-items: center;
        color: var(--color-base);
        text-decoration: none;
      }

      .brand-word {
        display: block;
        font-family: var(--font-family-serif);
        font-size: 30px;
        line-height: 1;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .brand-letter-large {
        font-size: 1.2em;
        font-weight: 500;
      }

      .brand-subtitle {
        display: block;
        margin-top: 3px;
        color: var(--color-base-subtle);
        font-size: 13px;
      }

      .home-nav {
        display: flex;
        align-items: center;
        gap: 18px;
        font-size: 13px;
      }

      .home-nav a {
        color: var(--color-base);
        text-decoration: none;
      }

      .home-nav a:hover {
        color: var(--color-link);
        text-decoration: underline;
      }

      .home-hero {
        padding: 44px 0 38px;
        max-width: 760px;
      }

      h1 {
        margin: 0;
        max-width: 700px;
        font-family: var(--font-family-serif);
        font-size: 44px;
        font-weight: 400;
        line-height: 1.1;
        letter-spacing: 0;
      }

      .home-intro {
        max-width: 650px;
        margin: 14px 0 0;
        color: var(--color-base-subtle);
        font-size: 16px;
        line-height: 1.6;
      }

      .home-search {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: center;
        max-width: 640px;
        margin-top: 24px;
        border: 1px solid var(--border-color-base);
        background: var(--background-color-base);
      }

      .home-search-icon {
        width: 18px;
        height: 18px;
        margin-left: 14px;
        color: var(--color-base-subtle);
      }

      .home-search input {
        min-width: 0;
        width: 100%;
        padding: 14px 12px;
        border: 0;
        color: var(--color-base);
        background: transparent;
        font: inherit;
        font-size: 15px;
        outline: none;
      }

      .home-search:focus-within {
        border-color: var(--color-link);
        box-shadow: inset 0 0 0 1px var(--color-link);
      }

      .home-search button {
        align-self: stretch;
        padding: 0 22px;
        border: 0;
        border-left: 1px solid var(--border-color-base);
        background: var(--color-progressive);
        color: white;
        font-weight: 700;
        cursor: pointer;
      }

      .home-search button:hover {
        background: var(--color-progressive-hover);
      }

      .search-suggestions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        max-width: 640px;
        margin-top: 10px;
      }

      .search-suggestions span {
        color: var(--color-base-subtle);
        font-size: 13px;
      }

      .search-suggestions a {
        color: var(--color-link);
        font-size: 13px;
        text-decoration: none;
      }

      .search-suggestions a:hover {
        text-decoration: underline;
      }

      .home-section {
        padding: 32px 0;
        border-top: 1px solid var(--border-color-subtle);
      }

      .section-heading {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
      }

      .section-heading h2 {
        margin: 0;
        font-family: var(--font-family-serif);
        font-size: 28px;
        font-weight: 400;
      }

      .section-heading a {
        color: var(--color-link);
        font-size: 13px;
        text-decoration: none;
      }

      .topic-grid,
      .article-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
      }

      .topic-link,
      .article-card {
        display: block;
        min-height: 100%;
        padding: 14px;
        border: 1px solid var(--border-color-subtle);
        background: var(--background-color-interactive);
        color: var(--color-base);
        text-decoration: none;
      }

      .topic-link:hover,
      .article-card:hover {
        border-color: var(--color-link);
        text-decoration: none;
      }

      .topic-link strong,
      .article-card strong {
        display: block;
        color: var(--color-link);
        font-size: 15px;
      }

      .topic-link span,
      .article-card span {
        display: block;
        margin-top: 6px;
        color: var(--color-base-subtle);
        font-size: 13px;
        line-height: 1.45;
      }

      .recent-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 10px;
      }

      .recent-item {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border-color-subtle);
      }

      .recent-link {
        color: var(--color-link);
        font-size: 15px;
        text-decoration: none;
      }

      .recent-link:hover {
        text-decoration: underline;
      }

      .recent-date {
        flex-shrink: 0;
        color: var(--color-base-subtle);
        font-size: 12px;
        white-space: nowrap;
      }

      .term-panel {
        padding-top: 4px;
      }

      .term-group ul {
        columns: 3;
        column-gap: 32px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .term-group li {
        break-inside: avoid;
        margin: 0 0 9px;
        line-height: 1.3;
      }

      .term-group a {
        color: var(--color-link);
        text-decoration: none;
      }

      .term-group a:hover {
        text-decoration: underline;
      }

      .more-terms {
        margin-top: 18px;
      }

      .alpha-nav {
        display: grid;
        grid-template-columns: repeat(26, minmax(0, 1fr));
        gap: 4px;
      }

      .alpha-nav button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        width: 100%;
        height: 34px;
        padding: 0;
        border: 1px solid var(--border-color-base);
        background: var(--background-color-base);
        color: var(--color-link);
        font: inherit;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
      }

      .alpha-nav button:hover,
      .alpha-nav button.active {
        border-color: var(--color-link);
        background: var(--background-color-interactive);
      }

      .alpha-nav button:disabled {
        border-color: var(--border-color-subtle);
        color: var(--color-base-subtle);
        cursor: not-allowed;
        opacity: 0.55;
      }

      .home-footer {
        padding-top: 24px;
        border-top: 1px solid var(--border-color-subtle);
        color: var(--color-base-subtle);
        font-size: 12px;
      }

      @media (max-width: 820px) {
        .home-header,
        .home-hero {
          display: block;
        }

        .home-nav {
          margin-top: 18px;
          flex-wrap: wrap;
        }

        .home-hero {
          padding-top: 32px;
        }

        h1 {
          font-size: 36px;
        }

        .home-search {
          grid-template-columns: auto minmax(0, 1fr);
        }

        .home-search button {
          grid-column: 1 / -1;
          padding: 12px;
          border-left: 0;
          border-top: 1px solid var(--border-color-base);
        }

        .topic-grid,
        .article-grid {
          grid-template-columns: 1fr;
        }

        .term-group ul {
          columns: 1;
        }

        .recent-item {
          flex-direction: column;
          gap: 2px;
        }

        .recent-date {
          white-space: normal;
        }

        .alpha-nav {
          gap: 2px;
        }

        .alpha-nav button {
          height: 30px;
          font-size: 11px;
        }
      }
    </style>
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>

    <main id="content" class="home-shell" tabindex="-1">
      <header class="home-header">
        <a href="/" class="home-brand" aria-label="Taopedia home">
          <span>
            <span class="brand-word"><span class="brand-letter-large">T</span>AOPEDI<span class="brand-letter-large">A</span></span>
            <span class="brand-subtitle">Bittensor Knowledge Base</span>
          </span>
        </a>
        <nav class="home-nav" aria-label="Primary">
          <a href="/wiki/special/allpages">Articles</a>
          <a href="/wiki/special/categories">Topics</a>
          <a href="/wiki/special/recentchanges">Recent changes</a>
          <a href="/wiki/special/mostlinkedpages">Most linked</a>
          <a href="/wiki/special/subnets">Subnets</a>
        </nav>
      </header>

      <section class="home-hero">
        <div>
          <h1>Bittensor concepts, organized.</h1>
          <p class="home-intro">Short reference pages for builders, validators, miners, and TAO holders.</p>
          <form class="home-search" action="/search/" method="get">
            <svg class="home-search-icon" viewBox="0 0 20 20" aria-hidden="true">
              <path d="M8.5 14.5a6 6 0 1 1 4.24-1.76l3.26 3.26-1.41 1.41-3.26-3.26A5.97 5.97 0 0 1 8.5 14.5Zm0-2a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" fill="currentColor" />
            </svg>
            <input type="search" name="q" placeholder="Search Taopedia" aria-label="Search Taopedia" autocomplete="off" />
            <button type="submit">Search</button>
          </form>
          <div class="search-suggestions" aria-label="Suggested searches">
            <span>{sortedPages.length} articles</span>
            <a href="/wiki/wallets/">wallets</a>
            <a href="/wiki/category/Staking/">staking</a>
            <a href="/wiki/yuma_consensus/">Yuma Consensus</a>
            <a href="/wiki/dynamic_tao/">Dynamic TAO</a>
          </div>
        </div>
      </section>

      <section class="home-section">
        <div class="section-heading">
          <h2>Start With A Topic</h2>
          <a href="/wiki/special/categories">All topics</a>
        </div>
        <div class="topic-grid">
          {topicCategories.map(([category, categoryPages]) => (
            <a class="topic-link" href={`/wiki/category/${category.replace(/ /g, '_')}/`}>
              <strong>{category}</strong>
              <span>{categoryPages.length} article{categoryPages.length !== 1 ? 's' : ''}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="home-section">
        <div class="section-heading">
          <h2>Core Articles</h2>
          <a href="/wiki/special/allpages">All articles</a>
        </div>
        <div class="article-grid">
          {featuredPages.map((page) => (
            <a class="article-card" href={`/wiki/${getPageSlug(page)}/`}>
              <strong>{page.data.title}</strong>
              {page.data.summary && <span>{page.data.summary}</span>}
            </a>
          ))}
        </div>
      </section>

      {featuredSubnets.length > 0 && (
        <section class="home-section">
          <div class="section-heading">
            <h2>Explore Subnets</h2>
            <a href="/wiki/special/subnets">All subnets</a>
          </div>
          <div class="article-grid">
            {featuredSubnets.map((subnet) => (
              <a class="article-card" href={`/wiki/${subnet.slug}/`}>
                <strong>Subnet {subnet.netuid}: {subnet.name}</strong>
                {subnet.summary && <span>{subnet.summary}</span>}
              </a>
            ))}
          </div>
        </section>
      )}

      {recentlyUpdated.length > 0 && (
        <section class="home-section">
          <div class="section-heading">
            <h2>Recently Updated</h2>
            <a href="/wiki/special/recentchanges">All recent changes</a>
          </div>
          <ul class="recent-list">
            {recentlyUpdated.map((change) => (
              <li class="recent-item">
                <a class="recent-link" href={`/wiki/${change.slug}/`}>{change.title}</a>
                <time class="recent-date" datetime={change.date}>{formatRevisionDate(change.date)}</time>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="home-section" id="article-index">
        <div class="section-heading">
          <h2 id="article-index-title">Articles Beginning With '{initialLetter}'</h2>
          <a href="/wiki/special/allpages">Open directory</a>
        </div>
        <div class="term-panel">
          {groupedPages.map(([letter, letterPages]) => (
            <section class="term-group" data-letter={letter} hidden={letter !== initialLetter}>
              <ul>
                {letterPages.map((page) => (
                  <li><a href={`/wiki/${getPageSlug(page)}/`}>{page.data.title}</a></li>
                ))}
              </ul>
            </section>
          ))}
          <div class="more-terms">
            <nav class="alpha-nav" aria-label="Article index letters">
              {'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').map((letter) => (
                <button
                  type="button"
                  data-index-letter={letter}
                  aria-pressed={letter === initialLetter ? 'true' : 'false'}
                  class:list={[letter === initialLetter && 'active']}
                  disabled={!alphaGroups.has(letter)}
                >
                  {letter}
                </button>
              ))}
            </nav>
          </div>
        </div>
      </section>

      <footer class="home-footer">
        Content is maintained in the Taopedia articles repository and published as a static wiki.
      </footer>
    </main>
    <script is:inline>
      const letterButtons = Array.from(document.querySelectorAll('[data-index-letter]'));
      const letterGroups = Array.from(document.querySelectorAll('[data-letter]'));
      const indexTitle = document.getElementById('article-index-title');

      function selectLetter(letter) {
        letterGroups.forEach((group) => {
          group.hidden = group.dataset.letter !== letter;
        });
        letterButtons.forEach((button) => {
          button.classList.toggle('active', button.dataset.indexLetter === letter);
          button.setAttribute('aria-pressed', button.dataset.indexLetter === letter ? 'true' : 'false');
        });
        if (indexTitle) {
          indexTitle.textContent = `Articles Beginning With '${letter}'`;
        }
      }

      letterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const letter = button.dataset.indexLetter;
          if (letter) {
            selectLetter(letter);
          }
        });
      });
    </script>

    <SearchSuggest />
  </body>
</html>
