---
import WikiLayout from '../layouts/WikiLayout.astro';
---

<WikiLayout
  title="Search"
  description="Search the Taopedia Bittensor knowledge base for articles on TAO, subnets, staking, mining, validation and consensus."
  robots="noindex"
>
  <div class="mw-body-content">
    <h1 class="firstHeading" id="search-heading">Search</h1>

    <div id="search-results" class="search-results" aria-live="polite">
      <p class="search-status">Use the search field in the header to find an article.</p>
    </div>
  </div>

  <script is:inline>
    const SEARCH_RESULT_BATCH_SIZE = 20;
    // Show only the most relevant topics (highest result counts) as facets, not
    // every topic that appears — too many options is noise.
    const MAX_FACETS = 8;
    const searchQuery = (new URLSearchParams(window.location.search).get('q') || '').trim();
    const resultsContainer = document.getElementById('search-results');
    const headingEl = document.getElementById('search-heading');
    let metadataEntriesPromise;

    // Topics the reader has toggled on to filter the results (empty = show all).
    const selectedTopics = new Set();
    // After a toggle rebuilds the facet buttons, restore keyboard focus to the
    // control the reader just used: the topic's button, or (after Clear) the
    // first facet. '' means "focus the first facet"; null means "no restore".
    let pendingFacetFocus = null;

    // Render the topic facets: one toggle button per topic present in the full
    // result set (with its count), plus a Clear button when any are active. The
    // counts are computed from the unfiltered query so they stay stable as the
    // reader toggles topics. onChange re-runs the current search with the new
    // selection. Facets only appear when there are at least two topics to choose
    // between (a single facet can't usefully narrow anything).
    function renderFacets(host, topicCounts, onChange) {
      host.textContent = '';
      // Only topics that actually have matches for this query — Pagefind returns
      // a count for every filter value, including zeros, which would be dead
      // facets.
      const topics = Object.keys(topicCounts)
        .filter((topic) => topicCounts[topic] > 0)
        .sort((a, b) => topicCounts[b] - topicCounts[a] || a.localeCompare(b, 'en', { numeric: true }))
        .slice(0, MAX_FACETS);
      if (topics.length < 2) return;

      const label = document.createElement('span');
      label.className = 'search-facets-label';
      label.id = 'search-facets-label';
      label.textContent = 'Filter by topic';
      host.appendChild(label);

      const group = document.createElement('div');
      group.className = 'search-facets';
      group.setAttribute('role', 'group');
      group.setAttribute('aria-labelledby', 'search-facets-label');
      host.appendChild(group);

      topics.forEach((topic) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'search-facet';
        const on = selectedTopics.has(topic);
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
        if (on) btn.classList.add('is-active');
        btn.textContent = topic + ' (' + topicCounts[topic] + ')';
        btn.addEventListener('click', () => {
          if (selectedTopics.has(topic)) selectedTopics.delete(topic);
          else selectedTopics.add(topic);
          pendingFacetFocus = topic;
          onChange();
        });
        group.appendChild(btn);
        if (pendingFacetFocus === topic) btn.focus();
      });

      if (selectedTopics.size) {
        const clear = document.createElement('button');
        clear.type = 'button';
        clear.className = 'search-facet search-facet-clear';
        clear.textContent = 'Clear filters';
        clear.addEventListener('click', () => {
          selectedTopics.clear();
          pendingFacetFocus = '';
          onChange();
        });
        group.appendChild(clear);
      }

      // Clearing removes the button that had focus, so move focus to the first
      // facet instead of letting it fall back to the document body.
      if (pendingFacetFocus === '') {
        const firstFacet = group.querySelector('.search-facet');
        if (firstFacet) firstFacet.focus();
      }
      pendingFacetFocus = null;
    }

    if (searchQuery) {
      document.title = `Search results for "${searchQuery}" - Taopedia`;
      if (headingEl) headingEl.textContent = 'Search results';
    }

    function normalize(value) {
      // Trim so accidental leading/trailing spaces in the metadata fallback
      // (astro dev, where Pagefind is absent) do not skew substring matches.
      return (value || '').trim().toLowerCase();
    }

    function setStatus(text) {
      if (!resultsContainer) return null;
      resultsContainer.innerHTML = '';
      const status = document.createElement('p');
      status.className = 'search-status';
      status.textContent = text;
      resultsContainer.appendChild(status);
      return status;
    }

    function countLabel(query, count) {
      return count
        ? `Found ${count} result${count === 1 ? '' : 's'} for "${query}"`
        : `No results found for "${query}"`;
    }

    function appendTopics(item, categories) {
      if (!categories || !categories.length) return;
      const topics = document.createElement('span');
      topics.className = 'search-topics';
      categories.forEach((category) => {
        const topic = document.createElement('span');
        topic.className = 'search-topic';
        topic.textContent = category;
        topics.appendChild(topic);
      });
      item.appendChild(topics);
    }

    function normalizeTopics(value) {
      if (!value) return [];
      return Array.isArray(value) ? value : [value];
    }

    function loadMoreLabel(remainingCount) {
      const nextCount = Math.min(SEARCH_RESULT_BATCH_SIZE, remainingCount);
      return `Load ${nextCount} more result${nextCount === 1 ? '' : 's'} (${remainingCount} remaining)`;
    }

    function loadMetadataEntries() {
      if (!metadataEntriesPromise) {
        metadataEntriesPromise = fetch('/search-data.json')
          .then((response) => (response.ok ? response.json() : []))
          .then((entries) => (Array.isArray(entries) ? entries : []))
          .catch(() => []);
      }
      return metadataEntriesPromise;
    }

    // Pagefind result: title + highlighted excerpt (excerpt HTML is sanitized by Pagefind).
    function renderPagefindResult(data) {
      const item = document.createElement('a');
      item.className = 'search-result-item';
      item.href = data.url;

      const title = document.createElement('span');
      title.className = 'search-title';
      title.textContent = (data.meta && data.meta.title) || data.url;
      item.appendChild(title);

      if (data.excerpt) {
        const excerpt = document.createElement('span');
        excerpt.className = 'search-summary';
        excerpt.innerHTML = data.excerpt;
        item.appendChild(excerpt);
      }

      appendTopics(item, normalizeTopics(data.filters && data.filters.category));
      return item;
    }

    // Fallback (used during `astro dev`, where no Pagefind index is built):
    // metadata-only match over title/summary/categories.
    function renderMetadataResult(entry) {
      const item = document.createElement('a');
      item.className = 'search-result-item';
      item.href = entry.url;

      const title = document.createElement('span');
      title.className = 'search-title';
      title.textContent = entry.title;
      item.appendChild(title);

      if (entry.summary) {
        const summary = document.createElement('span');
        summary.className = 'search-summary';
        summary.textContent = entry.summary;
        item.appendChild(summary);
      }

      appendTopics(item, entry.categories);
      return item;
    }

    async function runMetadataSearch(query) {
      const entries = await loadMetadataEntries();
      const needle = normalize(query);
      const matches = entries.filter((entry) => {
        const haystack = normalize(`${entry.title} ${entry.summary} ${(entry.categories || []).join(' ')}`);
        return haystack.includes(needle);
      });

      // Topic counts from the full match set (stable as topics are toggled).
      const topicCounts = {};
      matches.forEach((entry) => {
        (entry.categories || []).forEach((category) => {
          topicCounts[category] = (topicCounts[category] || 0) + 1;
        });
      });

      resultsContainer.textContent = '';
      const statusEl = document.createElement('p');
      statusEl.className = 'search-status';
      resultsContainer.appendChild(statusEl);
      const facetsHost = document.createElement('div');
      facetsHost.className = 'search-facets-host';
      resultsContainer.appendChild(facetsHost);
      const list = document.createElement('div');
      list.className = 'search-result-list';
      resultsContainer.appendChild(list);

      function applyFilters() {
        const filtered = selectedTopics.size
          ? matches.filter((entry) => (entry.categories || []).some((category) => selectedTopics.has(category)))
          : matches;
        renderFacets(facetsHost, topicCounts, applyFilters);
        // The headline reports the total results for the query; topic facets
        // narrow the view, not the query, so this stays constant as topics are
        // toggled.
        statusEl.textContent = countLabel(query, matches.length);
        list.textContent = '';
        filtered.forEach((entry) => list.appendChild(renderMetadataResult(entry)));
      }

      applyFilters();
    }

    async function runPagefindSearch(pagefind, query) {
      // Warm the filter index before searching: Pagefind loads it lazily, so a
      // search fired immediately after init() can return empty per-query filter
      // counts. pagefind.filters() forces the index to load first.
      if (typeof pagefind.filters === 'function') {
        try {
          await pagefind.filters();
        } catch (error) {
          // Filters unavailable — fall through; facets just won't render.
        }
      }

      // Topic counts come from the UNFILTERED query so the facet list and its
      // counts stay stable while the reader toggles topics.
      const baseSearch = await pagefind.search(query);
      const topicCounts = (baseSearch.filters && baseSearch.filters.category) || {};

      resultsContainer.textContent = '';
      const statusEl = document.createElement('p');
      statusEl.className = 'search-status';
      resultsContainer.appendChild(statusEl);
      const facetsHost = document.createElement('div');
      facetsHost.className = 'search-facets-host';
      resultsContainer.appendChild(facetsHost);
      const list = document.createElement('div');
      list.className = 'search-result-list';
      resultsContainer.appendChild(list);

      let loadMoreButton = null;

      async function applyFilters() {
        // Re-query Pagefind with the active topic filters (OR within the
        // category). With none selected, reuse the base search — no re-query.
        const search = selectedTopics.size
          ? await pagefind.search(query, { filters: { category: Array.from(selectedTopics) } })
          : baseSearch;
        const totalCount = search.results.length;

        renderFacets(facetsHost, topicCounts, applyFilters);
        // The headline reports the total results for the query; topic facets
        // narrow the view, not the query, so it stays constant (the unfiltered
        // base count) as topics are toggled. Pagination below uses the filtered
        // totalCount.
        statusEl.textContent = countLabel(query, baseSearch.results.length);
        list.textContent = '';
        if (loadMoreButton) {
          loadMoreButton.remove();
          loadMoreButton = null;
        }

        let renderedCount = 0;
        function updateLoadMoreButton() {
          if (!loadMoreButton) return;
          const remainingCount = totalCount - renderedCount;
          if (remainingCount <= 0) {
            loadMoreButton.remove();
            loadMoreButton = null;
            return;
          }
          loadMoreButton.disabled = false;
          loadMoreButton.textContent = loadMoreLabel(remainingCount);
        }

        async function loadNextBatch() {
          const nextResults = search.results.slice(renderedCount, renderedCount + SEARCH_RESULT_BATCH_SIZE);
          if (!nextResults.length) return;
          if (loadMoreButton) {
            loadMoreButton.disabled = true;
            loadMoreButton.textContent = 'Loading...';
          }
          const data = await Promise.all(nextResults.map((result) => result.data()));
          data.forEach((entry) => list.appendChild(renderPagefindResult(entry)));
          renderedCount += data.length;
          updateLoadMoreButton();
        }

        await loadNextBatch();

        if (renderedCount < totalCount) {
          loadMoreButton = document.createElement('button');
          loadMoreButton.type = 'button';
          loadMoreButton.className = 'search-load-more';
          updateLoadMoreButton();
          loadMoreButton.addEventListener('click', () => {
            loadNextBatch().catch(() => {
              if (!loadMoreButton) return;
              loadMoreButton.disabled = true;
              loadMoreButton.textContent = 'Could not load more results';
            });
          });
          resultsContainer.appendChild(loadMoreButton);
        }
      }

      await applyFilters();
    }

    async function loadPagefind() {
      try {
        // Path is built into `dist/pagefind/` by the `postbuild` step. Use a
        // variable so the dev bundler does not try to resolve it at build time.
        const modulePath = '/pagefind/pagefind.js';
        const pagefind = await import(modulePath);
        await pagefind.init();
        return pagefind;
      } catch (error) {
        return null;
      }
    }

    async function runSearch(query) {
      if (!query || !resultsContainer) return;
      setStatus(`Searching for "${query}"...`);
      const pagefind = await loadPagefind();
      if (pagefind) {
        try {
          await runPagefindSearch(pagefind, query);
          return;
        } catch (error) {
          // Fall through to metadata search if a query fails at runtime.
        }
      }
      await runMetadataSearch(query);
    }

    runSearch(searchQuery);
  </script>

  <style>
    :global(.search-results) {
      margin-top: 20px;
    }

    :global(.search-status) {
      color: var(--color-base-subtle);
      font-size: 14px;
    }

    :global(.search-result-list) {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    :global(.search-result-item) {
      display: block;
      padding: 14px 16px;
      border: 1px solid var(--border-color-subtle);
      background: var(--background-color-interactive);
      text-decoration: none;
      color: var(--color-base);
    }

    :global(.search-result-item:hover) {
      border-color: var(--color-link);
      text-decoration: none;
    }

    :global(.search-title) {
      display: block;
      color: var(--color-link);
      font-size: 16px;
      font-weight: 700;
    }

    :global(.search-summary) {
      display: block;
      margin-top: 6px;
      color: var(--color-base-subtle);
      line-height: 1.45;
    }

    :global(.search-topics) {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 10px;
    }

    :global(.search-topic) {
      display: inline-flex;
      padding: 2px 6px;
      border: 1px solid var(--border-color-subtle);
      background: var(--background-color-base);
      color: var(--color-base-subtle);
      font-size: 12px;
      line-height: 1.4;
    }

    :global(.search-facets-host:not(:empty)) {
      margin-top: 16px;
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 8px 12px;
    }

    :global(.search-facets-label) {
      color: var(--color-base-subtle);
      font-size: 13px;
    }

    :global(.search-facets) {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    :global(.search-facet) {
      padding: 3px 10px;
      border: 1px solid var(--border-color-subtle);
      background: var(--background-color-interactive);
      color: var(--color-link);
      font: inherit;
      font-size: 13px;
      cursor: pointer;
    }

    :global(.search-facet:hover) {
      border-color: var(--color-link);
    }

    :global(.search-facet:focus-visible) {
      outline: 2px solid var(--color-link);
      outline-offset: 1px;
    }

    :global(.search-facet.is-active) {
      background: var(--color-link);
      border-color: var(--color-link);
      color: var(--background-color-base);
    }

    :global(.search-facet-clear) {
      color: var(--color-base-subtle);
    }

    :global(.search-load-more) {
      margin-top: 16px;
      padding: 8px 12px;
      border: 1px solid var(--border-color-subtle);
      background: var(--background-color-interactive);
      color: var(--color-link);
      font: inherit;
      cursor: pointer;
    }

    :global(.search-load-more:hover) {
      border-color: var(--color-link);
    }

    :global(.search-load-more:disabled) {
      color: var(--color-base-subtle);
      cursor: default;
    }
  </style>
</WikiLayout>
