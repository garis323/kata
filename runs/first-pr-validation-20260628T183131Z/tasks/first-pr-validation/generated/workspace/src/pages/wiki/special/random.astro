---
import WikiLayout from '../../../layouts/WikiLayout.astro';

const pageDescription = 'Jump to a randomly selected article in the Taopedia Bittensor knowledge base.';
---

<WikiLayout title="Random article" description={pageDescription}>
  <div class="mw-body-content">
    <h1 class="firstHeading">Random article</h1>

    <p class="random-status" aria-live="polite">Taking you to a random article…</p>

    <noscript>
      <p>
        Random article selection needs JavaScript. You can browse every article on the
        <a href="/wiki/special/allpages/">All pages</a> directory instead.
      </p>
    </noscript>
  </div>

  <script is:inline>
    // Pick a random article from the same prebuilt metadata index the search
    // fallback already fetches (src/pages/search-data.json.ts), and replace the
    // current history entry so Back returns to the page the reader came from
    // rather than bouncing through this redirect.
    (async () => {
      const status = document.querySelector('.random-status');
      try {
        const response = await fetch('/search-data.json');
        const entries = response.ok ? await response.json() : [];
        const articleEntries = Array.isArray(entries)
          ? entries.filter((entry) => entry && typeof entry.url === 'string' && /^(?:https?:\/\/[^/]+)?\/wiki\/(?!special\/|category\/)[^?#]+\/$/.test(entry.url))
          : [];
        if (articleEntries.length > 0) {
          const choice = articleEntries[Math.floor(Math.random() * articleEntries.length)];
          if (choice) {
            window.location.replace(choice.url);
            return;
          }
        }
        throw new Error('no articles in search data');
      } catch (error) {
        if (status) {
          status.textContent = 'Could not pick a random article. Try the All pages directory instead.';
        }
      }
    })();
  </script>
</WikiLayout>
