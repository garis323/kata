---
import { getCollection } from 'astro:content';
import WikiLayout from '../../../layouts/WikiLayout.astro';
import { formatRevisionDate } from '../../../lib/format-date.js';
import { getPageSlug, historyForSlug } from '../../../lib/article-history';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((page) => {
    const slug = getPageSlug(page);
    // Precomputed once per route in getStaticPaths — the page body used to run
    // import.meta.glob on every history page, eagerly loading all of
    // public/history/**/*.json (350 full-glob evaluations per build) just to
    // read this one article's file. historyForSlug reads from the shared module-
    // level glob in article-history.ts instead. Mirrors history.json (#1043).
    return {
      params: { slug },
      props: { page, slug, history: historyForSlug(slug) },
    };
  });
}

const { page, slug, history } = Astro.props;
const articleUrl = `/wiki/${slug}/`;
const pageDescription = `Revision history for the Taopedia article "${page.data.title}".`;
---

<WikiLayout title={`Revision history of "${page.data.title}"`} description={pageDescription} image={`/og/${slug}.png`}>
  <div class="mw-body-content">
    <nav class="mw-article-toolbar">
      <a href={articleUrl}>Article</a>
      <a href={`/wiki/${slug}/history/`} class="active" aria-current="page">History</a>
    </nav>

    <h1 class="firstHeading">Revision history of "{page.data.title}"</h1>

    <p style="margin-bottom: 16px; font-size: 13px;">
      This page shows the edit history from Git. Each revision represents a commit that modified this article.
    </p>

    {history.length === 0 ? (
      <p>No revision history available yet.</p>
    ) : (
      <ul style="list-style: none; margin: 0; padding: 0;">
        {history.map((revision: any) => (
          <li style="padding: 12px; border: 1px solid var(--border-color-subtle); margin-bottom: 8px; background: var(--background-color-interactive);">
            <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
              <strong style="font-size: 13px;">
                <time datetime={revision.date}>
                  {formatRevisionDate(revision.date)}
                </time>
              </strong>
              <span style="font-size: 12px; color: var(--color-base-subtle);">
                {revision.authorName}
              </span>
            </div>
            <div style="font-size: 13px; margin-bottom: 8px;">
              {revision.message || '(no message)'}
            </div>
            <div style="font-size: 12px;">
              <code style="background: var(--background-color-neutral); padding: 2px 6px; border-radius: 2px; font-size: 11px;">
                {revision.sha.substring(0, 7)}
              </code>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</WikiLayout>
