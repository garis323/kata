---
import '../styles/wikipedia.css';
import '../styles/print.css';
import Seo from '../components/Seo.astro';
import SearchSuggest from '../components/SearchSuggest.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  path?: string;
  // Per-page feed alternates forwarded to <Seo> (e.g. a category hub's own feeds).
  feeds?: Array<{ type: string; title: string; href: string }>;
  robots?: string;
}

const { title, description, image, type = 'website', path, feeds, robots } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Seo title={title} description={description} image={image} type={type} path={path} feeds={feeds} robots={robots} />
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>

    <!-- Sidebar toggle is placed within article toolbars on narrow screens. -->
    
    <!-- Overlays -->
    <div class="sidebar-overlay"></div>
    
    <header class="mw-header">
      <div class="mw-header-content">
        <div class="mw-header-left">
          <a href="/" class="mw-logo">
            <div class="header-logo-container">
              <div class="header-globe">
                <img src="/logo.svg" alt="Taopedia logo" class="header-logo-img" />
              </div>
            </div>
            <span class="header-logo-text">
              <span class="logo-letter-large">T</span>AOPEDI<span class="logo-letter-large">A</span>
            </span>
          </a>
        </div>
        
        <div class="mw-header-center">
          <div class="mw-header-center-inner">
            <div class="mw-search-container">
              <form action="/search/" method="get" style="position: relative;">
                <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); pointer-events: none; opacity: 0.5;">
                  <path d="M7 12C9.76142 12 12 9.76142 12 7C12 4.23858 9.76142 2 7 2C4.23858 2 2 4.23858 2 7C2 9.76142 4.23858 12 7 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <input 
                  type="search" 
                  name="q" 
                  class="mw-search-input" 
                  placeholder="Search Taopedia" 
                  aria-label="Search"
                  style="padding-left: 36px;"
                />
              </form>
            </div>
          </div>
        </div>
        
        <nav class="mw-header-right" aria-label="Primary">
          <a href="/wiki/special/allpages">Articles</a>
          <a href="/wiki/special/categories">Topics</a>
        </nav>
      </div>
    </header>

    <div class="mw-page-container">
      <div class="mw-content-container">
        <aside class="mw-sidebar">
          <slot name="sidebar" />
        </aside>

        <main id="content" class="mw-body" tabindex="-1">
          <slot />
        </main>

        <aside class="mw-appearance" aria-labelledby="appearance-title">
          <div class="appearance-header">
            <h2 id="appearance-title">Appearance</h2>
            <button class="appearance-hide" type="button" aria-label="Hide appearance controls">hide</button>
          </div>

          <form class="appearance-form">
            <fieldset>
              <legend>Text</legend>
              <label>
                <input type="radio" name="text-size" value="small" />
                <span>Small</span>
              </label>
              <label>
                <input type="radio" name="text-size" value="standard" />
                <span>Standard</span>
              </label>
              <label>
                <input type="radio" name="text-size" value="large" />
                <span>Large</span>
              </label>
            </fieldset>

            <fieldset>
              <legend>Width</legend>
              <label>
                <input type="radio" name="content-width" value="narrow" />
                <span>Narrow</span>
              </label>
              <label>
                <input type="radio" name="content-width" value="standard" />
                <span>Standard</span>
              </label>
              <label>
                <input type="radio" name="content-width" value="wide" />
                <span>Wide</span>
              </label>
            </fieldset>

            <fieldset>
              <legend>Color</legend>
              <label>
                <input type="radio" name="color-theme" value="light" />
                <span>Light</span>
              </label>
              <label>
                <input type="radio" name="color-theme" value="dark" />
                <span>Dark</span>
              </label>
            </fieldset>
          </form>
        </aside>
      </div>
    </div>

    <footer class="mw-footer">
      <div class="mw-footer-links">
        <a href="/wiki/special/allpages">Articles</a>
        <a href="/wiki/special/categories">Topics</a>
        <a href="/wiki/special/recentchanges">Recent changes</a>
        <a href="/wiki/special/mostlinkedpages">Most linked</a>
        <a href="/wiki/special/subnets">Subnets</a>
        <span style="margin-left: auto;">Content available under <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a></span>
      </div>
    </footer>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        const query = new URLSearchParams(window.location.search).get('q')?.trim();
        if (!query) return;
        const searchInput = document.querySelector('.mw-search-input');
        if (searchInput) searchInput.value = query;
      });
    </script>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // TOC collapse/expand functionality
        const tocToggles = document.querySelectorAll('.toc-toggle');
        tocToggles.forEach(toggle => {
          toggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const parentLi = this.closest('li');
            const parentLevel = parseInt(parentLi.dataset.tocLevel);
            
            // Toggle collapsed state
            parentLi.classList.toggle('collapsed');
            
            // Find all subsections
            let nextLi = parentLi.nextElementSibling;
            while (nextLi && nextLi.dataset.tocLevel) {
              const nextLevel = parseInt(nextLi.dataset.tocLevel);
              
              // If we hit a same-level or higher-level heading, stop
              if (nextLevel <= parentLevel) {
                break;
              }
              
              // Toggle subsection visibility
              if (parentLi.classList.contains('collapsed')) {
                nextLi.style.display = 'none';
              } else {
                nextLi.style.display = 'flex';
              }
              
              nextLi = nextLi.nextElementSibling;
            }
          });
        });
        
        // Active section tracking for TOC
        const tocLinks = document.querySelectorAll('.toc-list a[href^="#"]');
        const headings = document.querySelectorAll('.mw-parser-output h2[id], .mw-parser-output h3[id], .mw-parser-output h4[id]');
        
        if (tocLinks.length > 0 && headings.length > 0) {
          // Create a map of heading IDs to TOC items
          const tocItemMap = new Map();
          tocLinks.forEach(link => {
            const id = link.getAttribute('href').substring(1);
            const li = link.closest('li');
            if (id && li) {
              tocItemMap.set(id, li);
            }
          });
          
          // Function to update active section
          function updateActiveSection() {
            let currentSection = null;
            const scrollPosition = window.scrollY + 100; // Offset for header
            
            // Find the current section based on scroll position
            for (let i = headings.length - 1; i >= 0; i--) {
              const heading = headings[i];
              if (heading.offsetTop <= scrollPosition) {
                currentSection = heading.id;
                break;
              }
            }
            
            // Update active class
            tocItemMap.forEach((li, id) => {
              if (id === currentSection) {
                li.classList.add('active');
              } else {
                li.classList.remove('active');
              }
            });
          }
          
          // Update on scroll with throttling
          let scrollTimeout;
          window.addEventListener('scroll', () => {
            if (scrollTimeout) {
              window.cancelAnimationFrame(scrollTimeout);
            }
            scrollTimeout = window.requestAnimationFrame(() => {
              updateActiveSection();
            });
          });
          
          // Update on load
          updateActiveSection();
        }
        
        const articleBody = document.querySelector('.mw-body');
        const appearancePanel = document.querySelector('.mw-appearance');
        const appearanceToggle = document.querySelector('.appearance-toggle');
        const appearanceHideBtn = document.querySelector('.appearance-hide');
        const textSizeInputs = document.querySelectorAll('input[name="text-size"]');
        const contentWidthInputs = document.querySelectorAll('input[name="content-width"]');
        const colorInputs = document.querySelectorAll('input[name="color-theme"]');
        const textSizes = ['small', 'standard', 'large'];
        const contentWidths = ['narrow', 'standard', 'wide'];
        const colorThemes = ['light', 'dark'];
        let appearanceManuallyHidden = false;

        function normalizePreference(value, allowedValues, fallback) {
          return allowedValues.includes(value) ? value : fallback;
        }

        // localStorage access throws when storage is unavailable (privacy modes,
        // sandboxed/partitioned contexts, cookies disabled) or full. Guard it so
        // a storage error can't abort this DOMContentLoaded handler and take the
        // rest of the page's interactivity (sidebar, responsive controls) with it.
        function readStoredPreference(key) {
          try {
            return localStorage.getItem(key);
          } catch {
            return null;
          }
        }

        function storePreference(key, value) {
          try {
            localStorage.setItem(key, value);
          } catch {
            // Storage unavailable — the preference just won't persist.
          }
        }

        function setCheckedInput(inputs, value) {
          inputs.forEach((input) => {
            input.checked = input.value === value;
          });
        }

        function applyTextSize(size) {
          if (!articleBody) return;
          const normalized = normalizePreference(size, textSizes, 'standard');
          textSizes.forEach((textSize) => articleBody.classList.remove(`text-${textSize}`));
          articleBody.classList.add(`text-${normalized}`);
          setCheckedInput(textSizeInputs, normalized);
          storePreference('taopedia-text-size', normalized);
        }

        function applyContentWidth(width) {
          if (!articleBody) return;
          const normalized = normalizePreference(width, contentWidths, 'standard');
          contentWidths.forEach((contentWidth) => {
            articleBody.classList.remove(`width-${contentWidth}`);
            document.body.classList.remove(`content-width-${contentWidth}`);
          });
          articleBody.classList.add(`width-${normalized}`);
          document.body.classList.add(`content-width-${normalized}`);
          setCheckedInput(contentWidthInputs, normalized);
          storePreference('taopedia-content-width', normalized);
          syncAppearanceState();
        }

        // Color theme applies to <html> (data-theme) so it covers the whole page,
        // not just the article body. An inline <head> script applies the stored
        // theme before paint to avoid a flash; this keeps it in sync at runtime.
        function applyColorTheme(theme) {
          const normalized = normalizePreference(theme, colorThemes, 'light');
          if (normalized === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
          setCheckedInput(colorInputs, normalized);
          storePreference('taopedia-color', normalized);
        }

        function appearanceRailFits() {
          if (!appearancePanel) return false;
          const wasHidden = appearancePanel.hidden;
          const hadOverlay = document.body.classList.contains('appearance-overlay-active');

          appearancePanel.hidden = false;
          document.body.classList.remove('appearance-overlay-active');
          const rect = appearancePanel.getBoundingClientRect();
          appearancePanel.hidden = wasHidden;
          document.body.classList.toggle('appearance-overlay-active', hadOverlay);

          return rect.left >= 16 && rect.right <= window.innerWidth - 16;
        }

        function syncAppearanceState() {
          if (!appearancePanel || !appearanceToggle) return;
          const constrained = !appearanceRailFits();

          if (constrained) {
            appearancePanel.hidden = !document.body.classList.contains('appearance-overlay-active');
            appearanceToggle.classList.add('visible');
            appearanceToggle.setAttribute('aria-expanded', appearancePanel.hidden ? 'false' : 'true');
            return;
          }

          document.body.classList.remove('appearance-overlay-active');
          appearancePanel.hidden = appearanceManuallyHidden;
          appearanceToggle.classList.toggle('visible', appearanceManuallyHidden);
          appearanceToggle.setAttribute('aria-expanded', appearanceManuallyHidden ? 'false' : 'true');
        }

        const savedTextSize = normalizePreference(readStoredPreference('taopedia-text-size'), textSizes, 'standard');
        const savedContentWidth = normalizePreference(readStoredPreference('taopedia-content-width'), contentWidths, 'standard');
        const savedColorTheme = normalizePreference(readStoredPreference('taopedia-color'), colorThemes, 'light');
        applyTextSize(savedTextSize);
        applyContentWidth(savedContentWidth);
        applyColorTheme(savedColorTheme);
        syncAppearanceState();

        textSizeInputs.forEach((input) => {
          input.addEventListener('change', () => applyTextSize(input.value));
        });

        contentWidthInputs.forEach((input) => {
          input.addEventListener('change', () => applyContentWidth(input.value));
        });

        colorInputs.forEach((input) => {
          input.addEventListener('change', () => applyColorTheme(input.value));
        });

        if (appearanceHideBtn && appearancePanel) {
          appearanceHideBtn.addEventListener('click', () => {
            appearanceManuallyHidden = true;
            appearancePanel.hidden = true;
            document.body.classList.remove('appearance-overlay-active');
            appearanceToggle?.classList.add('visible');
            appearanceToggle?.setAttribute('aria-expanded', 'false');
          });
        }

        if (appearanceToggle && appearancePanel) {
          appearanceToggle.addEventListener('click', () => {
            appearanceManuallyHidden = false;
            if (appearanceRailFits()) {
              document.body.classList.remove('appearance-overlay-active');
              appearancePanel.hidden = false;
              appearanceToggle.classList.remove('visible');
              appearanceToggle.setAttribute('aria-expanded', 'true');
            } else {
              document.body.classList.toggle('appearance-overlay-active');
              appearancePanel.hidden = !document.body.classList.contains('appearance-overlay-active');
              appearanceToggle.classList.add('visible');
              appearanceToggle.setAttribute('aria-expanded', appearancePanel.hidden ? 'false' : 'true');
            }
          });
        }
        
        // Sidebar toggle functionality
        const sidebarToggle = document.querySelector('.sidebar-toggle');
        const sidebar = document.querySelector('.mw-sidebar');
        const sidebarOverlay = document.querySelector('.sidebar-overlay');
        const tocHideBtn = document.querySelector('.toc-hide');
        
        // Helper functions for responsive behavior
        function isMobile() { return window.matchMedia('(max-width: 900px)').matches; }
        function isMidSize() { return window.matchMedia('(min-width: 901px) and (max-width: 1500px)').matches; }

        // Toggle sidebar
        if (sidebarToggle && sidebar && sidebarOverlay) {
          sidebarToggle.addEventListener('click', function() {
            if (isMobile()) {
              // Mobile panel behavior
              sidebar.classList.toggle('mobile-active');
              sidebarOverlay.classList.toggle('active');
            } else if (isMidSize()) {
              // Mid-size: use mobile-style overlay but with desktop styling
              sidebar.classList.toggle('mobile-active');
              sidebarOverlay.classList.toggle('active');
            } else {
              // Large desktop: collapse behavior
              document.body.classList.toggle('sidebar-collapsed');
            }
          });
          
          sidebarOverlay.addEventListener('click', function() {
            sidebar.classList.remove('mobile-active');
            sidebarOverlay.classList.remove('active');
          });
        }
        
        // TOC hide button collapses sidebar
        if (tocHideBtn) {
          tocHideBtn.addEventListener('click', function() {
            if (isMobile() || isMidSize()) {
              sidebar.classList.remove('mobile-active');
              sidebarOverlay.classList.remove('active');
            } else {
              document.body.classList.add('sidebar-collapsed');
            }
          });
        }

        // Clear collapse classes and overlays when switching between responsive modes
        const mq900 = window.matchMedia('(max-width: 900px)');
        const mq1500 = window.matchMedia('(max-width: 1500px)');
        
        function handleResponsiveChange() {
          // Always clear active overlays when switching modes
          sidebar?.classList.remove('mobile-active');
          sidebarOverlay?.classList.remove('active');

          // If we're in any overlay mode for the sidebar (<=1500) clear collapsed state
          if (isMobile() || mq1500.matches) {
            document.body.classList.remove('sidebar-collapsed');
          }
        }
        
        mq900.addEventListener('change', handleResponsiveChange);
        mq1500.addEventListener('change', handleResponsiveChange);
        window.addEventListener('resize', syncAppearanceState);
        
      });
    </script>

    <SearchSuggest />
  </body>
</html>
