---
import { getCollection } from 'astro:content';
import WikiLayout from '../../../layouts/WikiLayout.astro';
import { getPageSlug } from '../../../lib/article-history';
import { publishedTitleBySlug } from '../../../lib/site-feed-context';
import { sortInboundBacklinkEntries } from '../../../../scripts/article-backlinks.js';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  // Inbound links are computed at build time by scripts/build-linkgraph.js and
  // written to public/data/backlinks.json. Globbed inside getStaticPaths because
  // Astro runs this function in isolation from the module scope.
  const backlinksModules = import.meta.glob('../../../../public/data/backlinks.json', { eager: true }) as Record<
    string,
    { default?: Record<string, Array<{ from: string; fromTitle?: string }>> }
  >;
  const backlinksData = Object.values(backlinksModules)[0]?.default ?? {};

  // titleBySlug comes from public/data/slugmap.json — the same artifact
  // backlinks.json and the site-wide feeds read.
  const titleBySlug = publishedTitleBySlug();

  return pages.map((page) => {
    const slug = getPageSlug(page);
    // Precomputed once per route in getStaticPaths — the page body used to re-run
    // getCollection('pages') and rebuild titleBySlug on every article page just
    // to derive this article's sorted backlink list (O(N) per page). Mirrors
    // backlinks.json (#1042) and the category-page getStaticPaths fix (#1206).
    const backlinks = sortInboundBacklinkEntries(
      (backlinksData[slug] ?? [])
      .filter((entry) => titleBySlug[entry.from])
      .map((entry) => ({ slug: entry.from, title: titleBySlug[entry.from] })),
    );

    return {
      params: { slug },
      props: { page, slug, backlinks },
    };
  });
}

const { page, slug, backlinks } = Astro.props;

const articleUrl = `/wiki/${slug}/`;
const historyUrl = `/wiki/${slug}/history/`;
const backlinksUrl = `/wiki/${slug}/backlinks/`;
const pageTitle = `Pages that link to "${page.data.title}"`;
const pageDescription = `Articles across Taopedia that link to the "${page.data.title}" article.`;
---

<WikiLayout title={pageTitle} description={pageDescription}>
  <div class="mw-body-content">
    <nav class="mw-article-toolbar">
      <a href={articleUrl}>Article</a>
      <a href={historyUrl}>History</a>
      <a href={backlinksUrl} class="active" aria-current="page">What links here</a>
    </nav>

    <h1 class="firstHeading">{pageTitle}</h1>

    {backlinks.length === 0 ? (
      <p>No pages link to this article yet.</p>
    ) : (
      <div class="mw-parser-output">
        <p>
          The following {backlinks.length} {backlinks.length === 1 ? 'page links' : 'pages link'} to
          {' '}<a href={articleUrl}>{page.data.title}</a>:
        </p>
        <ul class="mw-whatlinkshere">
          {backlinks.map((link) => (
            <li class="mw-wlh-row"><a href={`/wiki/${link.slug}/`}>{link.title}</a></li>
          ))}
        </ul>
      </div>
    )}
  </div>
</WikiLayout>

<style>
  .mw-whatlinkshere {
    margin: 16px 0;
    padding-left: 24px;
  }
  .mw-wlh-row {
    padding: 4px 0;
    font-size: 14px;
  }
</style>
