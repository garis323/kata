---
import { getCollection } from 'astro:content';
import WikiLayout from '../../../layouts/WikiLayout.astro';
import CiteCopyButtons from '../../../components/CiteCopyButtons.astro';
import { getPageSlug, historyForSlug } from '../../../lib/article-history';
import { publishedTitleBySlug } from '../../../lib/article-metadata';
import { buildCitations, CITATION_FORMATS, CITATION_META } from '../../../../scripts/citations.js';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  const titleBySlug = publishedTitleBySlug();
  const origin = 'https://taopedia.org';

  return pages.map((page) => {
    const slug = getPageSlug(page);
    const title = titleBySlug[slug] ?? page.data.title;
    const lastRevision = historyForSlug(slug)[0]?.date ?? '';
    const url = `${origin}/wiki/${slug}/`;
    // Precomputed once per route in getStaticPaths — the page body used to call
    // historyForSlug again to derive the last-revision date for buildCitations().
    // Title comes from public/data/slugmap.json — same artifact cite.json reads.
    const citations = buildCitations({ title, url, slug, date: lastRevision });
    return {
      params: { slug },
      props: { page, slug, title, lastRevision, citations },
    };
  });
}

const { page, slug, title, lastRevision, citations } = Astro.props;

// MediaWiki's Special:CiteThisPage for one article: ready-made bibliographic
// citations. The date is the article's last revision (newest-first git history
// at public/history/<slug>.json — the same source as the article footer, the
// sitemap <lastmod>, and Special:RecentChanges); articles with no recorded
// history cite without a date rather than an invalid one. lastRevision and
// citations are precomputed once per route in getStaticPaths (see above).

const url = new URL(`/wiki/${slug}/`, Astro.site).toString();

const lastRevisionLabel = lastRevision
  ? new Date(lastRevision).toLocaleDateString('en-US', { timeZone: 'UTC', year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const articleUrl = `/wiki/${slug}/`;
const historyUrl = `/wiki/${slug}/history/`;
const backlinksUrl = `/wiki/${slug}/backlinks/`;
const citeUrl = `/wiki/${slug}/cite/`;
const pageTitle = `Cite "${title}"`;
const pageDescription = `Ready-made APA, MLA, Chicago, and BibTeX citations for the Taopedia article "${title}".`;
---

<WikiLayout title={pageTitle} description={pageDescription} image={`/og/${slug}.png`}>
  <div class="mw-body-content">
    <nav class="mw-article-toolbar">
      <a href={articleUrl}>Article</a>
      <a href={historyUrl}>History</a>
      <a href={backlinksUrl}>What links here</a>
      <a href={citeUrl} class="active" aria-current="page">Cite this page</a>
    </nav>

    <h1 class="firstHeading">Cite this page</h1>

    <div class="mw-parser-output">
      <p>Bibliographic details for <a href={articleUrl}>{title}</a>.</p>

      <dl class="mw-cite-details">
        <div class="mw-cite-row"><dt>Page title</dt><dd>{title}</dd></div>
        <div class="mw-cite-row"><dt>Author</dt><dd>{CITATION_META.author}</dd></div>
        <div class="mw-cite-row"><dt>Publisher</dt><dd>{CITATION_META.publisher}</dd></div>
        {lastRevisionLabel && (
          <div class="mw-cite-row">
            <dt>Date of last revision</dt>
            <dd><time datetime={lastRevision}>{lastRevisionLabel}</time> (UTC)</dd>
          </div>
        )}
        <div class="mw-cite-row"><dt>Permanent URL</dt><dd><a href={articleUrl}>{url}</a></dd></div>
      </dl>

      <h2>Citation styles</h2>
      <p>Copy a ready-made citation in your preferred style.</p>

      {CITATION_FORMATS.map((format) => (
        <div class="mw-cite-block">
          <h3 class="mw-cite-label">{format.label}</h3>
          <pre class="mw-cite-text" data-cite={format.key}>{citations[format.key]}</pre>
        </div>
      ))}

      <CiteCopyButtons />
    </div>
  </div>
</WikiLayout>

<style>
  .mw-cite-details {
    margin: 16px 0;
  }
  .mw-cite-row {
    display: flex;
    gap: 16px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-color-subtle);
    font-size: 14px;
  }
  .mw-cite-row dt {
    flex: 0 0 180px;
    color: var(--color-base-subtle);
  }
  .mw-cite-row dd {
    margin: 0;
    word-break: break-word;
  }
  .mw-cite-block {
    margin: 16px 0;
    position: relative;
  }
  /* The Copy button + live region are created by JS at runtime, so they never
     carry Astro's scoped style attribute; their rules are :global (anchored
     under the server-rendered .mw-cite-block) so they actually apply. */
  .mw-cite-block :global(.mw-cite-copy) {
    position: absolute;
    top: 0;
    right: 0;
    padding: 2px 10px;
    font-size: 13px;
    color: var(--color-link);
    background: var(--background-color-interactive);
    border: 1px solid var(--border-color-subtle);
    border-radius: 0;
    cursor: pointer;
  }
  .mw-cite-block :global(.mw-cite-copy):hover {
    text-decoration: underline;
  }
  .mw-cite-block :global(.mw-cite-copy):focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 1px;
  }
  .mw-cite-block :global(.mw-cite-copy.is-copied) {
    color: var(--color-base-subtle);
  }
  .mw-cite-block :global(.mw-cite-copy-status) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .mw-cite-label {
    font-size: 14px;
    margin: 0 0 6px;
  }
  .mw-cite-text {
    margin: 0;
    padding: 12px;
    background: var(--background-color-neutral);
    border: 1px solid var(--border-color-subtle);
    border-radius: 2px;
    font-size: 13px;
    white-space: pre-wrap;
    word-break: break-word;
  }
</style>
