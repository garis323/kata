---
import { buildStructuredData, serializeStructuredData } from '../../scripts/structured-data.js';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl: string;
  siteDescription?: string;
}

const { title, description, image, type = 'website', canonicalUrl, siteDescription } = Astro.props;

const siteUrl = new URL('/', Astro.site).toString();
const imageUrl = image ? new URL(image, Astro.site).toString() : undefined;
// The site brand mark (public/logo.svg) as an absolute URL for the Organization
// publisher node's logo, resolved like the canonical/image URLs.
const logoUrl = new URL('/logo.svg', Astro.site).toString();

// Article pages carry datePublished/dateModified derived from the source
// repository's commit history (already generated to public/history/<slug>.json).
// Revisions are newest-first, so the first record is the latest modification and
// the last is the original publication.
const historyModules = import.meta.glob('../../public/history/**/*.json', { eager: true }) as Record<string, any>;
const slugmapModules = import.meta.glob('../../public/data/slugmap.json', { eager: true }) as Record<string, any>;
const slugmap: Record<string, { categories?: string[] }> = Object.values(slugmapModules)[0]?.default ?? {};

let datePublished: string | undefined;
let dateModified: string | undefined;
let breadcrumbTopic: { name: string; item: string } | undefined;
if (type === 'article') {
  const slug = new URL(canonicalUrl).pathname.replace(/^\/wiki\//, '').replace(/\/$/, '');
  const historyData = historyModules[`../../public/history/${slug}.json`];
  const revisions: any[] = historyData?.default?.history ?? historyData?.history ?? [];
  if (revisions.length > 0) {
    dateModified = revisions[0]?.date;
    datePublished = revisions[revisions.length - 1]?.date;
  }
  // Primary topic for the breadcrumb = the article's first category, the same
  // source and order as the visible breadcrumb on the page, as a full URL.
  const primaryTopic = slugmap[slug]?.categories?.[0];
  if (primaryTopic) {
    breadcrumbTopic = {
      name: primaryTopic,
      item: new URL(`/wiki/category/${primaryTopic.replace(/ /g, '_')}/`, Astro.site).toString(),
    };
  }
}

const structuredData = buildStructuredData({
  siteUrl,
  canonicalUrl,
  imageUrl,
  logoUrl,
  title,
  description,
  type,
  datePublished,
  dateModified,
  siteDescription,
  breadcrumbTopic,
});
const json = serializeStructuredData(structuredData);
---

<script type="application/ld+json" set:html={json} />
