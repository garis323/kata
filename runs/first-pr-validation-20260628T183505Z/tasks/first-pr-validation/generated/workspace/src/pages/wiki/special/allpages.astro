---
import WikiLayout from '../../../layouts/WikiLayout.astro';
import { getCollection } from 'astro:content';
import { sortPagesByTitle } from '../../../lib/title-sort.js';

const pages = await getCollection('pages');
const sortedPages = sortPagesByTitle(pages);
const getPageSlug = (page: { id: string }) =>
  page.id.replace(/\/index\.(md|mdx)$/, '').replace(/\/index$/, '').replace(/\.(md|mdx)$/, '');
const pageCategories = (page: { data: { categories?: string[] } }) =>
  [...new Set(page.data.categories ?? [])];

const categoryIndex = new Map<string, typeof pages>();
for (const page of sortedPages) {
  // Dedupe a page's own categories so a frontmatter list that repeats a topic
  // does not list the article twice in a topic group — same rule statistics
  // (#1502) and buildCategories use.
  for (const category of pageCategories(page)) {
    const existing = categoryIndex.get(category) ?? [];
    existing.push(page);
    categoryIndex.set(category, existing);
  }
}

const priorityTopics = ['Wallets', 'Subnets', 'Mining', 'Staking', 'Consensus', 'Tokenomics'];
const topicFilters = priorityTopics
  .map((topic) => [topic, categoryIndex.get(topic)] as const)
  .filter((entry): entry is readonly [string, typeof pages] => Boolean(entry[1]));

// Articles whose categories include none of the featured topics would
// otherwise not be rendered anywhere in the directory, so the title filter
// could never find them. Collect them into a final catch-all group.
// sortedPages is already title-ordered, so the filtered list stays ordered.
const featuredTopicSet = new Set(priorityTopics);
const otherPages = sortedPages.filter(
  (page) => !pageCategories(page).some((category) => featuredTopicSet.has(category)),
);

const groupedArticles = [
  ...topicFilters.map(([topic, topicPages]) => ({
    topic,
    pages: sortPagesByTitle(topicPages),
    categoryHref: `/wiki/category/${topic.replace(/ /g, '_')}/`,
  })),
  ...(otherPages.length > 0 ? [{ topic: 'Other topics', pages: otherPages, categoryHref: null }] : []),
];
---

<WikiLayout title="Articles" description="Browse the full directory of Taopedia articles in the Bittensor knowledge base.">
  <div class="mw-body-content">
    <h1 class="firstHeading">Articles</h1>

    <div class="article-directory">
      <div class="directory-tools">
        <label class="directory-search">
          <span>Filter articles</span>
          <input type="search" id="article-filter" placeholder="Search by title, summary, or topic..." />
        </label>

        <div class="topic-filter" role="group" aria-label="Topic filters">
          <button type="button" class="active" data-topic="all" aria-pressed="true">All</button>
          {topicFilters.map(([topic, topicPages]) => (
            <button type="button" data-topic={topic} aria-pressed="false">{topic} <span>{topicPages.length}</span></button>
          ))}
        </div>
      </div>

      <p class="directory-count">
        <strong>{sortedPages.length}</strong> articles across <strong>{categoryIndex.size}</strong> topics
      </p>

      <div class="featured-directory" data-article-group data-topic="all">
        {sortedPages.slice(0, 3).map((page) => (
          <a
            class="article-card"
            href={`/wiki/${getPageSlug(page)}/`}
            data-article-card
            data-title={page.data.title.toLowerCase()}
            data-summary={(page.data.summary ?? '').toLowerCase()}
            data-topics={pageCategories(page).join('|')}
          >
            <strong>{page.data.title}</strong>
            {page.data.summary && <span>{page.data.summary}</span>}
          </a>
        ))}
      </div>

      <div class="article-groups">
        {groupedArticles.map(({ topic, pages, categoryHref }) => (
          <section class="article-group" data-article-group data-topic={topic}>
            <div class="article-group-heading">
              <h2>{topic}</h2>
              {categoryHref && <a href={categoryHref}>View topic</a>}
            </div>
            <ul>
              {pages.map((page) => (
                <li
                  data-article-card
                  data-title={page.data.title.toLowerCase()}
                  data-summary={(page.data.summary ?? '').toLowerCase()}
                  data-topics={pageCategories(page).join('|')}
                >
                  <a href={`/wiki/${getPageSlug(page)}/`}>{page.data.title}</a>
                  {page.data.summary && <span>{page.data.summary}</span>}
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    </div>
  </div>

  <script is:inline>
    const searchInput = document.getElementById('article-filter');
    // Only the filter buttons carry click behaviour; the featured-directory
    // container and the article-group sections also use [data-topic], so scope
    // the selector to the buttons to avoid binding handlers to whole sections.
    const topicButtons = Array.from(document.querySelectorAll('.topic-filter button[data-topic]'));
    const articleCards = Array.from(document.querySelectorAll('[data-article-card]'));
    const groups = Array.from(document.querySelectorAll('[data-article-group]'));
    let selectedTopic = 'all';

    function normalize(value) {
      // Trim so whitespace-only filter input shows every article (same rule as
      // /search/ treating a blank q as "no query").
      return (value || '').trim().toLowerCase();
    }

    function applyFilters() {
      const query = normalize(searchInput?.value);

      articleCards.forEach((card) => {
        const topics = card.dataset.topics || '';
        const text = `${card.dataset.title || ''} ${card.dataset.summary || ''} ${topics}`.toLowerCase();
        const matchesTopic = selectedTopic === 'all' || topics.split('|').includes(selectedTopic);
        const matchesQuery = !query || text.includes(query);
        card.hidden = !(matchesTopic && matchesQuery);
      });

      groups.forEach((group) => {
        const visibleItems = group.querySelectorAll('[data-article-card]:not([hidden])').length;
        const matchesGroupTopic = selectedTopic === 'all' || group.dataset.topic === selectedTopic;
        group.hidden = !matchesGroupTopic || visibleItems === 0;
      });
    }

    topicButtons.forEach((button) => {
      button.addEventListener('click', () => {
        selectedTopic = button.dataset.topic || 'all';
        topicButtons.forEach((btn) => {
          const isActive = btn === button;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', applyFilters);
  </script>
</WikiLayout>

<style>
  .article-directory {
    display: grid;
    gap: 24px;
  }

  .directory-tools {
    display: grid;
    gap: 14px;
    padding: 16px;
    border: 1px solid var(--border-color-subtle);
    background: var(--background-color-interactive);
  }

  .directory-search span {
    display: block;
    margin-bottom: 6px;
    color: var(--color-base-subtle);
    font-size: 12px;
    font-weight: 700;
  }

  .directory-search input {
    width: 100%;
    padding: 11px 12px;
    border: 1px solid var(--border-color-base);
    font: inherit;
  }

  .topic-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .topic-filter button {
    padding: 7px 10px;
    border: 1px solid var(--border-color-subtle);
    background: var(--background-color-base);
    color: var(--color-base);
    cursor: pointer;
    font: inherit;
    font-size: 13px;
  }

  .topic-filter button.active,
  .topic-filter button:hover {
    border-color: var(--color-link);
    color: var(--color-link);
  }

  .topic-filter span {
    color: var(--color-base-subtle);
    font-size: 12px;
  }

  .directory-count {
    margin: 0;
    color: var(--color-base-subtle);
    font-size: 13px;
  }

  .featured-directory {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .article-card {
    display: block;
    padding: 14px;
    border: 1px solid var(--border-color-subtle);
    background: var(--background-color-base);
    text-decoration: none;
  }

  .article-card strong,
  .article-group li a {
    color: var(--color-link);
    font-weight: 700;
    text-decoration: none;
  }

  .article-card span,
  .article-group li span {
    display: block;
    margin-top: 5px;
    color: var(--color-base-subtle);
    font-size: 13px;
    line-height: 1.45;
  }

  .article-card:hover,
  .article-group li:hover {
    border-color: var(--color-link);
  }

  .article-groups {
    display: grid;
    gap: 22px;
  }

  .article-group {
    padding-top: 4px;
  }

  .article-group-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid var(--border-color-subtle);
    margin-bottom: 10px;
  }

  .article-group-heading h2 {
    margin: 0;
    border: 0;
  }

  .article-group-heading a {
    color: var(--color-link);
    font-size: 13px;
    text-decoration: none;
  }

  .article-group ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-group li {
    padding: 12px;
    border: 1px solid var(--border-color-subtle);
    background: var(--background-color-interactive);
  }

  [hidden] {
    display: none !important;
  }

  @media (max-width: 780px) {
    .featured-directory,
    .article-group ul {
      grid-template-columns: 1fr;
    }
  }
</style>
